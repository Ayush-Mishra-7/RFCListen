# ============================================================
# RFCListen — Environment Variables
# Copy this file to .env and fill in values as needed.
# ============================================================

# Backend server
PORT=3000

# Directory where fetched RFC .txt files are cached locally
# (avoids re-fetching from rfc-editor.org on every request)
RFC_CACHE_DIR=./cache

# CORS — comma-separated list of allowed frontend origins
# Example: http://localhost:8080,https://rfclisten.example.com
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ─── Optional: Cloud TTS (leave blank to use browser Web Speech API) ────────

# Google Cloud Text-to-Speech
GOOGLE_TTS_API_KEY=

# AWS Polly
AWS_POLLY_ACCESS_KEY=
AWS_POLLY_SECRET_KEY=
AWS_POLLY_REGION=us-east-1

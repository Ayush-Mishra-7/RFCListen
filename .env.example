# ============================================================
# RFCListen — Environment Variables
# Copy this file to .env and fill in values as needed.
# ============================================================

# Backend server
PORT=3000

# Directory where fetched RFC .txt files are cached locally
# (avoids re-fetching from rfc-editor.org on every request)
RFC_CACHE_DIR=./cache

# Maximum age of the RFC metadata index before a background refresh is started.
RFC_INDEX_MAX_AGE_SECONDS=86400

# Minimum interval between automatic background refresh attempts.
RFC_INDEX_REFRESH_MIN_INTERVAL_SECONDS=3600

# CORS — comma-separated list of allowed frontend origins
# Local development:
#   ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Production (update with your GitHub Pages / custom domain):
#   ALLOWED_ORIGINS=https://your-username.github.io,http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
